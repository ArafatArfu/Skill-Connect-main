<div class="sc-dash">
    <button class="sc-dash-toggle" id="sc-dash-toggle" type="button" aria-label="Toggle sidebar" aria-expanded="true">
        <span class="sc-dash-toggle-bar"></span>
        <span class="sc-dash-toggle-bar"></span>
        <span class="sc-dash-toggle-bar"></span>
    </button>

    <aside class="sc-dash-sidebar" role="navigation" aria-label="Program management">
        <div class="sc-dash-brand">
            <span class="sc-dash-logo">{{sitename}}</span>
            <span class="sc-dash-tag">{{#str}}programmanagement, local_skillconnect{{/str}}</span>
        </div>

        <nav class="sc-dash-nav">
            <span class="sc-dash-nav-label">{{#str}}programs, local_skillconnect{{/str}}</span>
            <ul>
                {{#programs}}
                    <li>
                        <a href="{{url}}" class="sc-dash-link {{#active}}is-active{{/active}}">
                            <span class="sc-dash-ic sc-dash-ic-{{key}}" aria-hidden="true"></span>
                            <span class="sc-dash-link-text">{{name}}</span>
                        </a>
                    </li>
                {{/programs}}
            </ul>
        </nav>

        {{#hasmodules}}
        <nav class="sc-dash-nav">
            <span class="sc-dash-nav-label">Management</span>
            <ul>
                {{#modules}}
                    <li>
                        <a href="{{url}}" class="sc-dash-link {{#active}}is-active{{/active}}">
                            <span class="sc-dash-ic sc-dash-ic-mgmt" aria-hidden="true"></span>
                            <span class="sc-dash-link-text">{{name}}</span>
                        </a>
                    </li>
                {{/modules}}
            </ul>
        </nav>
        {{/hasmodules}}

        <div class="sc-dash-sidefoot">
            <a class="sc-dash-footlink" href="{{liveurl}}" target="_blank" rel="noopener">
                {{#str}}viewlive, local_skillconnect{{/str}} <span aria-hidden="true">&nearr;</span>
            </a>
            <a class="sc-dash-footlink" href="{{siteurl}}">{{#str}}backtosite, local_skillconnect{{/str}}</a>
        </div>
    </aside>

    <main class="sc-dash-main">
        {{{content}}}
    </main>

    <script>
    (function () {
        var dash = document.querySelector('.sc-dash');
        var btn = document.getElementById('sc-dash-toggle');
        if (!dash || !btn) { return; }
        var KEY = 'scDashSidebarCollapsed';
        function apply(collapsed) {
            dash.classList.toggle('is-collapsed', collapsed);
            btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        }
        try {
            if (localStorage.getItem(KEY) === '1') { apply(true); }
        } catch (e) {}
        btn.addEventListener('click', function () {
            var collapsed = !dash.classList.contains('is-collapsed');
            apply(collapsed);
            try { localStorage.setItem(KEY, collapsed ? '1' : '0'); } catch (e) {}
        });
    })();
    </script>
</div>
