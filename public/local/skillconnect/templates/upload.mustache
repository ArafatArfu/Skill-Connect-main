<div class="sc-dash-card">
    <h2 class="sc-dash-card-title">{{#str}}excel, local_skillconnect{{/str}}</h2>
    <p class="sc-dash-card-sub">{{#str}}exceluploaddesc, local_skillconnect{{/str}}</p>

    {{#hasresult}}

    <div class="sc-mgmt-section">{{#str}}previewsummary, local_skillconnect{{/str}}</div>
    <div class="sc-mgmt-grid-3 sc-upload-summary" style="margin-bottom: 18px;">
        <div class="sc-mgmt-field">
            <label>{{#str}}excelvalidrows, local_skillconnect{{/str}}</label>
            <strong>{{#importresult}}{{inserted}}{{/importresult}}</strong>
        </div>
        <div class="sc-mgmt-field">
            <label>{{#str}}excelinvalidrows, local_skillconnect{{/str}}</label>
            <strong>{{#importresult}}{{failed}}{{/importresult}}</strong>
        </div>
        <div class="sc-mgmt-field">
            <label>{{#str}}excelduplicaterows, local_skillconnect{{/str}}</label>
            <strong>{{#importresult}}{{skipped}}{{/importresult}}</strong>
        </div>
    </div>

    {{#hasuploadedrecords}}
    <div class="sc-mgmt-section">Uploaded Records</div>
    <div style="overflow-x: auto; margin-bottom: 18px;">
        <table class="sc-data-table">
            <thead>
                <tr>
                    <th>Row</th>
                    <th>School Name</th>
                    <th>Month</th>
                    <th>Year</th>
                    <th>Student Name</th>
                    <th>Father's Name</th>
                    <th>Class</th>
                    <th>Division</th>
                    <th>District</th>
                    <th>Upazila/Thana</th>
                    <th>Mobile</th>
                    <th>Email</th>
                    <th>Gender</th>
                </tr>
            </thead>
            <tbody>
                {{#uploadedrecords}}
                <tr>
                    <td>{{row}}</td>
                    <td>{{school}}</td>
                    <td>{{month}}</td>
                    <td>{{year}}</td>
                    <td>{{name}}</td>
                    <td>{{father_name}}</td>
                    <td>{{class}}</td>
                    <td>{{division}}</td>
                    <td>{{district}}</td>
                    <td>{{upazila}}</td>
                    <td>{{mobile}}</td>
                    <td>{{email}}</td>
                    <td>{{gender}}</td>
                </tr>
                {{/uploadedrecords}}
            </tbody>
        </table>
    </div>
    {{/hasuploadedrecords}}

    <div class="sc-mgmt-actions" style="border: 0; padding-top: 0;">
        <a href="{{downloadurl}}" class="sc-dash-btn sc-dash-btn-ghost">
            {{#str}}exceltemplate, local_skillconnect{{/str}}
        </a>
        <a href="upload.php?program={{programkey}}" class="sc-dash-btn sc-dash-btn-primary">Upload Another File</a>
    </div>

    {{/hasresult}}

    {{^hasresult}}
    <div class="sc-mgmt-actions" style="margin-bottom: 24px;">
        <a href="{{downloadurl}}" class="sc-dash-btn sc-dash-btn-ghost">
            {{#str}}exceltemplate, local_skillconnect{{/str}}
        </a>
    </div>

    <form method="post" enctype="multipart/form-data" class="sc-mgmt-form">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="sc-mgmt-field">
            <label for="excelfile">{{#str}}excelupload, local_skillconnect{{/str}}</label>
            <input type="file" name="excelfile" id="excelfile" accept=".xlsx,.xls" required>
        </div>

        <div class="sc-mgmt-actions">
            <button type="submit" class="sc-dash-btn sc-dash-btn-primary">{{#str}}excelupload, local_skillconnect{{/str}}</button>
        </div>
    </form>
    {{/hasresult}}
</div>
