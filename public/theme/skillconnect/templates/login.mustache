{{> theme_skillconnect/header }}
<main id="page-content" class="sc-auth-page">
    <div class="sc-container sc-auth-grid">
        <section class="sc-auth-panel" aria-label="Login or registration form">
            <div class="sc-auth-heading">
                <span class="sc-auth-mark"><svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm7 8a7 7 0 0 0-14 0v1h14v-1Z"/></svg></span>
                <div><h1>Welcome to {{sitename}}</h1><p>Sign in or create an account to continue learning.</p></div>
            </div>
            <div class="sc-auth-content">{{{maincontent}}}</div>
        </section>
        <aside class="sc-auth-art">
            <img src="{{heroimage}}" alt="Students learning together">
            <div><strong>Learn. Empower. Grow.</strong><span>Courses, volunteering and certificates in one place.</span></div>
        </aside>
    </div>
</main>
{{> theme_skillconnect/footer }}
