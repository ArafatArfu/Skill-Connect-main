{{> theme_skillconnect/header }}

<main id="page-content" class="sc-front-main">
    <section class="sc-hero">
        <div class="sc-container sc-hero-grid">
            <div class="sc-hero-copy">
                <h1>
                    {{heroline1}}<br>
                    {{heroline2}} <span>{{herohighlight1}}</span> &amp;<br>
                    <span>{{herohighlight2}}</span>
                </h1>
                <p>{{herodescription}}</p>
                <div class="sc-hero-buttons">
                    <a class="sc-btn sc-btn-primary" href="{{programsurl}}">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 11a4 4 0 1 0-3.7-5.5A5 5 0 0 1 14 9.2c.7.5 1.4 1.1 2 1.8Zm-8 0a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0 2c-4.4 0-7 2.2-7 5v2h10v-2c0-1.7.7-3.1 2-4.2A11.5 11.5 0 0 0 8 13Zm8 0c-.8 0-1.6.1-2.3.3A5.8 5.8 0 0 1 16 18v2h7v-2c0-2.8-2.6-5-7-5Z"/></svg>
                        {{explorebutton}}
                    </a>
                    <a class="sc-btn sc-btn-outline" href="{{volunteerurl}}">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21S3 15.4 3 8.7C3 5.6 5.3 3 8.3 3c1.6 0 3 .8 3.7 2 .7-1.2 2.1-2 3.7-2C18.7 3 21 5.6 21 8.7 21 15.4 12 21 12 21Z"/></svg>
                        {{volunteerbutton}}
                    </a>
                </div>
            </div>
            <div class="sc-hero-art">
                <img src="{{heroimage}}" alt="Students learning together with a volunteer">
            </div>
        </div>
    </section>

    <section class="sc-stats" aria-label="Impact statistics">
        <div class="sc-container sc-stats-grid">
            <article class="sc-stat-card">
                <span class="sc-stat-icon sc-stat-icon-pink"><svg viewBox="0 0 24 24"><path d="m2 9 10-5 10 5-10 5L2 9Zm4 3.1V17c3 2.3 9 2.3 12 0v-4.9l-6 3-6-3ZM21 11v6h-2v-5l2-1Z"/></svg></span>
                <div><strong>{{stat1number}}</strong><span>{{stat1label}}</span></div>
            </article>
            <article class="sc-stat-card">
                <span class="sc-stat-icon sc-stat-icon-pink"><svg viewBox="0 0 24 24"><path d="M8 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm8 0a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM8 13c-4.4 0-7 2.2-7 5v3h14v-3c0-2.8-2.6-5-7-5Zm8 0c-.7 0-1.3 0-1.9.2A6.4 6.4 0 0 1 17 18v3h6v-3c0-2.8-2.6-5-7-5Z"/></svg></span>
                <div><strong>{{stat2number}}</strong><span>{{stat2label}}</span></div>
            </article>
            <article class="sc-stat-card">
                <span class="sc-stat-icon sc-stat-icon-pink"><svg viewBox="0 0 24 24"><path d="M4 2h14v10.3a5 5 0 0 0-2-.3V4H6v16h7.1c.5.8 1.1 1.5 1.9 2H4V2Zm4 4h6v2H8V6Zm0 4h6v2H8v-2Zm8 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm0 2 1 2 2 .3-1.5 1.4.4 2-1.9-1-1.9 1 .4-2-1.5-1.4 2-.3 1-2Z"/></svg></span>
                <div><strong>{{stat3number}}</strong><span>{{stat3label}}</span></div>
            </article>
        </div>
    </section>

    <section class="sc-programs" id="featured-programs">
        <div class="sc-container">
            <h2 class="sc-section-title">{{featuredtitle}}</h2>
            <div class="sc-program-grid">
                <article class="sc-program-card">
                    <span class="sc-program-icon is-blue"><svg viewBox="0 0 24 24"><path d="M3 4h18v13H3V4Zm2 2v9h14V6H5Zm3 13h8v2H8v-2Z"/></svg></span>
                    <div><h3>{{program1title}}</h3><p>{{program1description}}</p><a href="{{program1url}}">{{learnmore}} <span>→</span></a></div>
                </article>
                <article class="sc-program-card">
                    <span class="sc-program-icon is-green"><svg viewBox="0 0 24 24"><path d="M3 4h18v13H8l-5 4V4Zm5 6a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm4 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm4 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/></svg></span>
                    <div><h3>{{program2title}}</h3><p>{{program2description}}</p><a href="{{program2url}}">{{learnmore}} <span>→</span></a></div>
                </article>
                <article class="sc-program-card">
                    <span class="sc-program-icon is-yellow"><svg viewBox="0 0 24 24"><path d="M12 2 1 21h22L12 2Zm0 5 6 11H6l6-11Zm-1 3v4h2v-4h-2Zm0 6v2h2v-2h-2Z"/></svg></span>
                    <div><h3>{{program3title}}</h3><p>{{program3description}}</p><a href="{{program3url}}">{{learnmore}} <span>→</span></a></div>
                </article>
            </div>
        </div>
    </section>

    <section class="sc-volunteer-banner">
        <div class="sc-container sc-volunteer-inner">
            <div class="sc-volunteer-art"><img src="{{volunteerimage}}" alt="Volunteer team illustration"></div>
            <div class="sc-volunteer-copy">
                <h2>{{volunteertitle}}</h2>
                <p>{{volunteerdescription}}</p>
                <a class="sc-btn sc-btn-primary" href="{{volunteerurl}}">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21S3 15.4 3 8.7C3 5.6 5.3 3 8.3 3c1.6 0 3 .8 3.7 2 .7-1.2 2.1-2 3.7-2C18.7 3 21 5.6 21 8.7 21 15.4 12 21 12 21Z"/></svg>
                    {{volunteerregisterbutton}}
                </a>
            </div>
        </div>
    </section>

    {{#hasmaincontent}}
    <section class="sc-moodle-front-content">
        <div class="sc-container">{{{maincontent}}}</div>
    </section>
    {{/hasmaincontent}}
</main>

{{> theme_skillconnect/footer }}
