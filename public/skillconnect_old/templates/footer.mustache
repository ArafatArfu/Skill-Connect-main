<footer class="sc-footer">
    <div class="sc-container sc-footer-grid">
        <section>
            <a class="sc-brand sc-footer-brand" href="{{homeurl}}">
                <img src="{{logoimage}}" alt="" class="sc-brand-logo">
                <span class="sc-brand-text">
                    <strong>SkillConnect</strong>
                    <small>Learn • Empower • Grow</small>
                </span>
            </a>
            <p>
                We empower students and communities through skills,
                education and volunteering to build a better tomorrow.
            </p>
            <div class="sc-socials" aria-label="Social media">
                <span>f</span><span>◎</span><span>♥</span><span>in</span>
            </div>
        </section>

        <section>
            <h3>Quick Links</h3>
            <a href="{{homeurl}}">Home</a>
            <a href="{{programsurl}}">Programs</a>
            <a href="{{coursesurl}}">Courses</a>
            <a href="{{volunteerurl}}">Volunteer</a>
            <a href="{{contacturl}}">Contact</a>
        </section>

        <section>
            <h3>Contact Us</h3>
            <p>✉ info@skillconnect.org</p>
            <p>☎ +880 1700 000000</p>
            <p>⌖ Dhaka, Bangladesh</p>
        </section>

        <section>
            <h3>Stay Connected</h3>
            <p>Subscribe for updates on programs, courses and events.</p>
            <form action="{{newsletterurl}}" method="post" class="sc-newsletter">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input
                    type="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="Enter your email"
                    aria-label="Email address">
                <button type="submit">Subscribe</button>
            </form>
        </section>
    </div>

    <div class="sc-footer-bottom">
        © {{currentyear}} SkillConnect. All Rights Reserved.
    </div>
</footer>
